# ── Browser (public) ─────────────────────────────────────────────────────────
# Local dev (default): omit these or point at ws://127.0.0.1:9944 after deploy:local

# Portaldot mainnet
# NEXT_PUBLIC_WS_ENDPOINT=wss://mainnet.portaldot.io
# NEXT_PUBLIC_REGISTRY_ADDRESS=5Fqv...
# NEXT_PUBLIC_RESOLVER_ADDRESS=5Etz...
# NEXT_PUBLIC_REVERSE_ADDRESS=5EaJ...
# NEXT_PUBLIC_REGISTRAR_ADDRESS=5Fwo...
# NEXT_PUBLIC_ATTESTATION_ADDRESS=5EnP...

# ── Server (community registrar deploy API) ───────────────────────────────────
# Funded account that pays contract instantiation gas (never commit the real seed)
# PNS_DEPLOYER_SEED=//YourMainnetDeployer
# PNS_WS_ENDPOINT=wss://mainnet.portaldot.io
# PNS_REGISTRY_ADDRESS=5Fqv...
